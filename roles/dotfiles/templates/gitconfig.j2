# {{ ansible_managed }}
[user]
	name = {{ git_user_name }}
	email = {{ git_user_email }}

[init]
	defaultBranch = {{ git_default_branch }}

[pull]
	rebase = true

[push]
	autoSetupRemote = true
	default = simple

[fetch]
	prune = true

[core]
	editor = nvim
	autocrlf = input

[color]
	ui = auto

[alias]
	st = status
	co = checkout
	br = branch
	ci = commit
	lg = log --oneline --graph --decorate --all
	last = log -1 HEAD
	unstage = reset HEAD --
